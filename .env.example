# =============================================================================
# Segit-DataHarmony - Variables de entorno
# =============================================================================
# Copiar a .env y completar valores.
# Nunca commitear .env al repositorio.
# =============================================================================

# --- API (FastAPI) ---
# Usado cuando ejecutas la API localmente (sin Docker)
DATABASE_URL=postgresql+psycopg2://postgres:postgres@localhost:5432/dataharmony
REDIS_URL=redis://localhost:6379/0
CORS_ORIGINS=http://localhost:3000
LOG_LEVEL=INFO
LOG_JSON=true
DEBUG=false

# --- PostgreSQL (solo si corres postgres local) ---
POSTGRES_USER=postgres
POSTGRES_PASSWORD=postgres
POSTGRES_DB=dataharmony

# --- Azure AD / Microsoft Entra ID ---
# App registration: https://entra.microsoft.com
# AUTH_MICROSOFT_ENTRA_ID_ISSUER = https://login.microsoftonline.com/<TENANT_ID>/v2.0
AZURE_TENANT_ID=
AZURE_CLIENT_ID=
AUTH_SKIP_VALIDATION=false

# Cifrado de contraseñas de data_sources (generar clave segura)
ENCRYPTION_KEY=

# --- Web (Next.js) .env.local ---
# AUTH_SECRET=<generar con: npx auth secret>
# AUTH_MICROSOFT_ENTRA_ID_ID=<Client ID>
# AUTH_MICROSOFT_ENTRA_ID_SECRET=<Client Secret>
# AUTH_MICROSOFT_ENTRA_ID_ISSUER=https://login.microsoftonline.com/<TENANT_ID>/v2.0
# NEXT_PUBLIC_USE_MICROSOFT_AUTH=true
# NEXT_PUBLIC_API_URL=http://localhost:8000
