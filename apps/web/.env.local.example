# Next.js - Auth y API
# Copiar a .env.local (obligatorio para Docker: el servicio web usa env_file)

# Obligatorio para Auth.js
AUTH_SECRET=

# Microsoft Entra ID (opcional en dev - sin config usar Credentials)
AUTH_MICROSOFT_ENTRA_ID_ID=
AUTH_MICROSOFT_ENTRA_ID_SECRET=
AUTH_MICROSOFT_ENTRA_ID_ISSUER=https://login.microsoftonline.com/<TENANT_ID>/v2.0

# true = mostrar botón "Continuar con Microsoft" en login
NEXT_PUBLIC_USE_MICROSOFT_AUTH=false

# URL de la API FastAPI (usada por el navegador)
NEXT_PUBLIC_API_URL=http://localhost:8000

# Solo cuando el frontend corre en Docker: URL interna para el servidor Next (Route Handlers BFF)
# En desarrollo local con npm run dev no hace falta
# INTERNAL_API_URL=http://api:8000
